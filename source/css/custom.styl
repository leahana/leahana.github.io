// 自定义样式 - 圆角和质感优化

// 通用圆角样式
.kratos-hentry
  border-radius: 12px
  transition: box-shadow 0.3s ease, transform 0.3s ease

.kratos-hentry:hover
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15) !important

.kratos-page-inner
  border-radius: 16px

.kratos-entry-border
  border-radius: 12px

// 侧边栏组件圆角
#kratos-widget-area .widget
  border-radius: 12px
  transition: box-shadow 0.3s ease, transform 0.3s ease

#kratos-widget-area .widget:hover
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1) !important

// 按钮圆角
.btn
  border-radius: 8px !important

// 卡片容器圆角
.kratos-card
  border-radius: 12px

// 导航栏圆角（如果有独立容器）
.kratos-topnav
  border-radius: 0 0 16px 16px

// 面包屑圆角
.kratos-breadcrumb
  border-radius: 8px

// 状态框圆角
.kratos-status
  border-radius: 8px

// 折叠框圆角
.collapse-box-control
  border-radius: 8px

// 分页按钮圆角
.pagination a,
.pagination span
  border-radius: 8px

// 面板圆角
.panel
  border-radius: 12px

// 输入框圆角
.form-control,
.input-group-addon
  border-radius: 8px

// 代码块圆角
pre
  border-radius: 8px

// 图片圆角
.kratos-page-content img,
.kratos-entry-thumb img
  border-radius: 8px
